      "text/plain": [
       "            Nb_valeurs_negatives  Montant_negatif_total\n",
       "Date                                                   \n",
       "2012-05-11                    19                -950.22\n",
       "2011-06-10                    18                -179.06\n",
       "2011-12-30                    18               -1839.87\n",
       "2010-12-31                    18               -2221.42\n",
       "2010-05-07                    17                -180.87\n",
       "2011-01-07                    16                -529.69\n",
       "2012-04-27                    14                -516.42\n",
