    "      <th style=\"padding:10px; text-align:left; border:1px solid #45475a; color: white;\">Traduction analytique</th>\n",
    "      <th style=\"padding:10px; text-align:left; border:1px solid #45475a; color: white;\">Livrable attendu</th>\n",
    "    </tr>\n",
    "  </thead>\n",
    "  <tbody>\n",
    "    <tr style=\"background:#1e1e2e;\">\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color:#89b4fa;\"><strong>BD-1</strong></td>\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color: white;\">Directeur de magasin</td>\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color: white;\">Anticiper les ventes de la semaine prochaine</td>\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color: white;\">Prédire <code style=\"background:#313244; padding:2px 5px; border-radius:3px; color:#cba6f7;\">Weekly_Sales</code> par Store × Dept, horizon 1–12 semaines</td>\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color: white;\">Prévisions hebdomadaires avec intervalles de confiance</td>\n",
    "    </tr>\n",
    "    <tr style=\"background:#2a2a3e;\">\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color:#89b4fa;\"><strong>BD-2</strong></td>\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color: white;\">Responsable marketing</td>\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color: white;\">Savoir quand et où lancer des promos</td>\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color: white;\">Quantifier l'impact des MarkDowns sur <code style=\"background:#313244; padding:2px 5px; border-radius:3px; color:#cba6f7;\">Weekly_Sales</code></td>\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color: white;\">Simulateur d'impact promotionnel + ROI estimé</td>\n",
    "    </tr>\n",
    "    <tr style=\"background:#1e1e2e;\">\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color:#89b4fa;\"><strong>BD-3</strong></td>\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color: white;\">Directeur de magasin</td>\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color: white;\">Éviter les ruptures de stock</td>\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color: white;\">Calculer les niveaux de stock optimaux par département</td>\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color: white;\">Alertes automatiques si probabilité de rupture &gt; 20%</td>\n",
    "    </tr>\n",
    "    <tr style=\"background:#2a2a3e;\">\n",
    "      <td style=\"padding:9px; border:1px solid #45475a; color:#89b4fa;\"><strong>BD-4</strong></td>\n",
