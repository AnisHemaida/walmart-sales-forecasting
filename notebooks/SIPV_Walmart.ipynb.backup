   "source": [
    "### <span id=\"135\" style=\"color:#2E86C1;\">1.3.5 Détecter et gérer les valeurs aberrantes</span>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "ac01db0d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "=======================================================\n",
      "DÉTECTION DES VALEURS ABERRANTES — Weekly_Sales\n",
      "=======================================================\n",
      "  Q1           :     2,079.65 $\n",
      "  Q3           :    20,205.85 $\n",
      "  IQR          :    18,126.20 $\n",
      "  Borne inf    :   -25,109.65 $\n",
      "  Borne sup    :    47,395.16 $\n",
