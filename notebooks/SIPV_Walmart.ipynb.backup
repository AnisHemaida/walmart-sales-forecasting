    "# ── 1.3.7 Validation de la cohérence des données avant analyse ────────────────\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\"VALIDATION FINALE — df_train\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "checks = {}\n",
    "\n",
    "# 1) Plus de valeurs manquantes\n",
    "checks['Aucune valeur manquante'] = df_train.isnull().sum().sum() == 0\n",
    "\n",
    "# 2) Date bien en datetime\n",
    "checks['Date → datetime64'] = str(df_train['Date'].dtype) == 'datetime64[ns]'\n",
    "\n",
    "# 3) Weekly_Sales toujours présent\n",
    "checks['Weekly_Sales présent'] = 'Weekly_Sales' in df_train.columns\n",
    "\n",
    "# 4) Nb lignes inchangé (jointure n'a pas créé de doublons)\n",
    "checks[f'Nb lignes conservé ({len(df_train):,})'] = len(df_train) > 400_000\n",
    "\n",
    "# 5) Couverture complète Store × Dept × Semaine\n",
    "nb_combinaisons = df_train.groupby(['Store', 'Dept']).ngroups\n",
    "checks[f'Combinaisons Store×Dept ({nb_combinaisons})'] = nb_combinaisons > 2_000\n",
    "\n",
    "# 6) IsHoliday uniquement 0 ou 1\n",
    "checks['IsHoliday = 0 ou 1 uniquement'] = set(df_train['IsHoliday'].unique()).issubset({0, 1})\n",
    "\n",
    "# 7) Type = 0, 1 ou 2 uniquement\n",
    "checks['Type = 0, 1 ou 2 uniquement'] = set(df_train['Type'].unique()).issubset({0, 1, 2})\n",
    "\n",
    "print()\n",
    "for desc, ok in checks.items():\n",
    "    print(f\"  {'✅' if ok else '❌'}  {desc}\")\n",
    "\n",
    "print(\"\\n── Statistiques descriptives finales — Weekly_Sales ──\")\n",
