       "      <th>2012-04-27</th>\n",
       "      <td>14</td>\n",
       "      <td>-516.42</td>\n",
       "    </tr>\n",
       "    <tr>\n",
       "      <th>2010-12-03</th>\n",
       "      <td>14</td>\n",
       "      <td>-1611.82</td>\n",
       "    </tr>\n",
       "    <tr>\n",
       "      <th>2011-04-01</th>\n",
       "      <td>14</td>\n",
       "      <td>-836.93</td>\n",
       "    </tr>\n",
       "    <tr>\n",
