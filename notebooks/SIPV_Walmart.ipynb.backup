   "source": [
    "import plotly.graph_objects as go\n",
    "from plotly.subplots import make_subplots\n",
    "\n",
    "# ── Évolution temporelle des variables économiques ───────────────────────────\n",
    "# Objectif : suivre l'évolution mensuelle des ventes et des variables macro\n",
    "\n",
    "# 1) Sécuriser les colonnes temporelles\n",
    "df_train['Date'] = pd.to_datetime(df_train['Date'])\n",
    "if 'Year' not in df_train.columns:\n",
    "    df_train['Year'] = df_train['Date'].dt.year\n",
    "if 'Month' not in df_train.columns:\n",
    "    df_train['Month'] = df_train['Date'].dt.month\n",
    "\n",
    "# 2) Agrégation mensuelle pour lisser les variations\n",
    "monthly_economic = df_train.groupby(['Year', 'Month'], as_index=False).agg({\n",
    "    'Weekly_Sales': 'mean',\n",
    "    'CPI': 'mean',\n",
    "    'Unemployment': 'mean',\n",
    "    'Fuel_Price': 'mean',\n",
    "})\n",
    "\n",
    "# 3) Index temporel (1er jour du mois)\n",
    "monthly_economic['Date'] = pd.to_datetime(monthly_economic[['Year', 'Month']].assign(Day=1))\n",
    "\n",
    "# 4) Graphique avec Plotly (axe secondaire)\n",
    "fig = make_subplots(specs=[[{\"secondary_y\": True}]])\n",
    "\n",
    "# Ventes (axe principal)\n",
    "fig.add_trace(\n",
    "    go.Scatter(\n",
    "        x=monthly_economic['Date'],\n",
    "        y=monthly_economic['Weekly_Sales'],\n",
    "        name='Ventes moyennes',\n",
    "        line=dict(color='#2E86C1', width=3),\n",
    "    ),\n",
    "    secondary_y=False,\n",
    " )\n",
    "\n",
    "# Variables économiques (axe secondaire)\n",
    "for var, name, color in [\n",
    "    ('CPI', 'CPI (Inflation)', '#E74C3C'),\n",
    "    ('Unemployment', 'Chômage (%)', '#27AE60'),\n",
    "    ('Fuel_Price', 'Prix carburant ($)', '#F39C12'),\n",
    " ]:\n",
    "    fig.add_trace(\n",
    "        go.Scatter(\n",
    "            x=monthly_economic['Date'],\n",
    "            y=monthly_economic[var],\n",
    "            name=name,\n",
    "            line=dict(color=color, width=2, dash='dot'),\n",
    "        ),\n",
    "        secondary_y=True,\n",
    "    )\n",
    "\n",
    "fig.update_layout(\n",
    "    title='Évolution des ventes et variables macroéconomiques (mensuel)',\n",
    "    xaxis_title='Date',\n",
    "    legend=dict(orientation='h', yanchor='bottom', y=1.02, xanchor='right', x=1),\n",
    " )\n",
    "fig.update_yaxes(title_text='Ventes moyennes ($)', secondary_y=False)\n",
    "fig.update_yaxes(title_text='Variables économiques', secondary_y=True)\n",
    "\n",
    "# Sauvegarde (si kaleido est installé)\n",
    "try:\n",
    "    fig.write_image('../images/1.5.3_economic_trends.png')\n",
    "except Exception as e:\n",
    "    print('Note: sauvegarde Plotly impossible (kaleido manquant?).', e)\n",
    "\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cc7cc231",
   "metadata": {},
   "source": [
    "📌 **Interprétation**\n",
    "\n",
    "- Les ventes mensuelles fluctuent fortement, avec des pics marqués en fin d’année.\n",
    "\n",
    "- Ces variations traduisent surtout un effet de saisonnalité et de promotions.\n",
    "\n",
    "- Le `CPI`, `Unemployment` et le `Fuel_Price` évoluent plus progressivement.\n",
    "\n",
    "- Les variables macroéconomiques n’expliquent donc pas directement les pics de ventes.\n",
    "\n",
    "- Elles restent utiles comme variables complémentaires dans le modèle prédictif.\n"
   ]
  },
