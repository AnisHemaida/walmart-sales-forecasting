    "# ── Vérification / Exemple d'une ligne de jointure ─────────────────────────\n",
    "\n",
    "example = train.iloc[0]  # Exemple d'une ligne du dataset train\n",
    "\n",
    "store = example['Store']\n",
    "date  = example['Date']\n",
    "holiday = example['IsHoliday']\n",
    "\n",
    "print(\"► Ligne dans TRAIN\") \n",
    "display(train[(train['Store']==store) & (train['Date']==date)].head())\n",
    "\n",
    "print(\"► Ligne correspondante dans FEATURES\")\n",
    "display(features[(features['Store']==store) & (features['Date']==date) & (features['IsHoliday']==holiday)])\n",
    "\n",
    "print(\"► Ligne correspondante dans STORES\")\n",
    "display(stores[stores['Store']==store])\n",
    "\n",
    "print(\"► Résultat après jointure\")\n",
    "display(df_train[(df_train['Store']==store) & (df_train['Date']==date)].head())"
   ]
  },
